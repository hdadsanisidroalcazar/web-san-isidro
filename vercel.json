{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildEnv": {
    "ASTRO_TELEMETRY_DISABLED": "1"
  },
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
