---
import type { ImageMetadata } from 'astro';
import Lightbox from '../common/Lightbox.astro';

export interface Props {
  folder: string;
}

const { folder } = Astro.props;

const imageFiles = import.meta.glob<ImageMetadata>('../../../public/images/galerias/**/*.{png,jpg,webp,jpeg,avif}', {
  import: 'default',
  eager: true,
});

const folderFiles = Object.keys(imageFiles).filter((image) => image.search(folder) >= 0);
const imageSrcs = folderFiles.map((image) => imageFiles[image]);
const gallery = 'gallery-' + folder.replace(/\s+/g, '-');
---

<div
  id={gallery}
  class="not-prose mx-auto w-full columns-1 gap-3 sm:columns-2 lg:columns-3 xl:columns-3 [column-gap:0.75rem]"
  itemscope
  itemtype="http://schema.org/ImageGallery"
>
  <Lightbox id={gallery} images={imageSrcs} />
</div>
