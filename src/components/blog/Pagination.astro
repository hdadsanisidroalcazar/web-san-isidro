---
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';
import Button from '~/components/ui/Button.astro';

export interface Props {
  prevUrl: string;
  nextUrl: string;
  prevText?: string;
  nextText?: string;
}

const { prevUrl, nextUrl, prevText = 'Más nuevos', nextText = 'Más antiguos' } = Astro.props;
---

{
  (prevUrl || nextUrl) && (
    <nav aria-label="Paginación" class="container flex">
      <div class="flex flex-row mx-auto container justify-between">
        <Button
          variant="tertiary"
          class={`md:px-3 px-3 mr-2 ${!prevUrl ? 'invisible' : ''}`}
          href={prevUrl ? getPermalink(prevUrl) : undefined}
          {...(!prevUrl ? { 'aria-disabled': 'true', tabindex: '-1' } : {})}
        >
          <Icon name="tabler:chevron-left" class="w-6 h-6" />
          <p class="ml-2">{prevText}</p>
        </Button>

        <Button
          variant="tertiary"
          class={`md:px-3 px-3 ${!nextUrl ? 'invisible' : ''}`}
          href={nextUrl ? getPermalink(nextUrl) : undefined}
          {...(!nextUrl ? { 'aria-disabled': 'true', tabindex: '-1' } : {})}
        >
          <span class="mr-2">{nextText}</span>
          <Icon name="tabler:chevron-right" class="w-6 h-6" />
        </Button>
      </div>
    </nav>
  )
}
