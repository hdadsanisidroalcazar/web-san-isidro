---
import 'photoswipe/style.css';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  id: string;
  images: ImageMetadata[];
}

const { id, images } = Astro.props;

const imagetitles = images.map((image) => image.src.split('/').reverse()[0].split('.')[0].replace(/-|_/g, ' '));
---

<lightbox-gallery data-id={id}>
  {
    images.map((image, i) => (
      <figure
        itemscope
        itemtype="http://schema.org/ImageObject"
        class="gallery-item my-1 inline-block w-full overflow-hidden rounded-md bg-gray-200 dark:bg-gray-800 lg:my-2"
      >
        <a
          href={image.src}
          itemprop="contentUrl"
          data-pswp-width={image.width}
          data-pswp-height={image.height}
          data-pswp-caption={imagetitles[i]}
          class="gallery-link relative block overflow-hidden"
          aria-label={`Ver imagen: ${imagetitles[i]}`}
        >
          <Image
            src={image}
            alt={imagetitles[i]}
            width={600}
            height={Math.round((image.height * 600) / image.width)}
            format="webp"
            class="gallery-img w-full rounded-md transition-transform duration-300 ease-out"
            itemprop="thumbnail"
          />
          <span class="gallery-overlay absolute inset-0 flex items-center justify-center rounded-md bg-black/0 transition-all duration-300">
            <span class="gallery-icon flex h-10 w-10 items-center justify-center rounded-full bg-white/90 opacity-0 shadow-lg transition-all duration-300 scale-75">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0zm-3-1v2m-1-1h2" />
              </svg>
            </span>
          </span>
        </a>
      </figure>
    ))
  }
</lightbox-gallery>

<style>
  .gallery-link:hover .gallery-img,
  .gallery-link:focus .gallery-img {
    transform: scale(1.04);
  }

  .gallery-link:hover .gallery-overlay,
  .gallery-link:focus .gallery-overlay {
    background-color: rgba(0, 0, 0, 0.25);
  }

  .gallery-link:hover .gallery-icon,
  .gallery-link:focus .gallery-icon {
    opacity: 1;
    transform: scale(1);
  }

  .gallery-link {
    cursor: zoom-in;
  }

  /* PhotoSwipe caption styling */
  :global(.pswp__custom-caption) {
    background: rgba(0, 0, 0, 0.6);
    font-size: 0.85rem;
    color: #fff;
    width: 100%;
    padding: 6px 16px;
    text-align: center;
    position: absolute;
    bottom: 0;
    left: 0;
    text-transform: capitalize;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  class LightboxGallery extends HTMLElement {
    connectedCallback() {
      const id = this.dataset.id!;

      const lightbox = new PhotoSwipeLightbox({
        gallery: this,
        children: 'a[data-pswp-width]',
        pswpModule: () => import('photoswipe'),
        padding: { top: 20, bottom: 40, left: 10, right: 10 },
        showHideAnimationType: 'zoom',
        showAnimationDuration: 250,
        hideAnimationDuration: 200,
        bgOpacity: 0.92,
        loop: true,
        wheelToZoom: true,
      });

      // Add caption from data-pswp-caption attribute
      lightbox.on('uiRegister', () => {
        lightbox.pswp?.ui?.registerElement({
          name: 'custom-caption',
          order: 9,
          isButton: false,
          appendTo: 'root',
          html: '',
          onInit: (el: HTMLElement, pswp: any) => {
            pswp.on('change', () => {
              const currSlideEl = pswp.currSlide?.data?.element as HTMLAnchorElement | undefined;
              const caption = currSlideEl?.dataset?.pswpCaption;
              if (caption) {
                el.innerHTML = caption;
                el.className = 'pswp__custom-caption';
              } else {
                el.innerHTML = '';
              }
            });
          },
        });
      });

      lightbox.init();
    }
  }

  if (!customElements.get('lightbox-gallery')) {
    customElements.define('lightbox-gallery', LightboxGallery);
  }
</script>
